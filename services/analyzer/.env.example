# TruthNet Analyzer - Variables de entorno
# Copia este archivo a .env y configura los valores necesarios

# API key de Groq para el LLM (requerida para análisis de veredictos)
# Obtén tu API key en: https://console.groq.com/keys
GROQ_API_KEY=tu_api_key_aqui

# Puerto del servidor (opcional, por defecto 8000)
PORT=8000

# Nivel de logging (opcional: DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Host permitido para CORS (por defecto: http://localhost:3001 para NestJS)
ALLOWED_ORIGINS=http://localhost:3001